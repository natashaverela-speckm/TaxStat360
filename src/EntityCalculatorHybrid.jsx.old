      }}>
        <div style={{ flex: 1, height: '1px', background: '#e2e8f0' }}></div>
        Need more advanced entity management?
        <div style={{ flex: 1, height: '1px', background: '#e2e8f0' }}></div>
      </div>

      {/* Advanced Section */}
      <div style={{
